      "estimated_effort": "2-3 days"
    }
  },
  "data_model": {
    "entities": [
      "Business",
      "Scan",
      "AICitation",
      "GEOScore",
      "Competitor",
      "Alert",
      "ActionItem",
      "Report"
    ]
  },
  "api_specification": {
    "version": "v1",
    "base_url": "/api/v1",
    "authentication": "Bearer token (JWT)",
    "endpoint_groups": [
      "businesses",
      "scans",
      "geo_scores",
      "competitors",
      "citations",
      "alerts",
      "action_items",
      "reports",
      "trends",
      "webhooks"
    ]
  },
  "scoring_algorithm": {
    "name": "GEO Visibility Score v2.0",
    "components": {
      "visibility": {
        "weight": 0.4,
        "formula": "min(100, (mention_rate * 100 * 0.40) + (top_3_rate * 100 * 0.35) + (rank_1_rate * 100 * 0.25))"
      },
      "authority": {
        "weight": 0.35,
        "formula": "(direct * 1.0 + listed * 0.7 + contextual * 0.3) / total_mentions * 100"
      },
      "momentum": {
        "weight": 0.25,
        "formula": "clamp(50 + (trend_velocity * 500), 0, 100)"
      }
    },
    "overall": "round(visibility * 0.40 + authority * 0.35 + momentum * 0.25, 1)",
    "benchmarks": {
      "0-25": "Invisible",
      "26-50": "Inconsistent",
      "51-75": "Solid",
      "76-90": "Authority",
      "91-100": "Dominant"
    }
  },
  "query_templates": {
    "service_location": [
      "best {trade} in {city}",
      "top rated {trade} near {neighborhood}",
      "recommended {trade} in {city} {state}",
      "emergency {trade} {city}"
    ],
    "problem_location": [
      "my roof is leaking who should I call in {city}",
      "burst pipe emergency {city}",
      "kitchen remodel contractor {neighborhood}"
    ],
    "comparison": [
      "best {trade} vs {trade} in {city}",
